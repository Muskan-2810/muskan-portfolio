# EmailJS — required for the Contact form to actually send messages.
# Create a free account at https://www.emailjs.com, then set these to your
# Service ID, Template ID, and Public Key. Copy this file to .env.local and
# fill in real values — .env.local is gitignored and never committed.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
